{
	"name": "@stateful-mcp/cli",
	"version": "0.3.0",
	"description": "Administrative CLI tool for Stateful framework",
	"keywords": [
		"cli",
		"admin",
		"stateful",
		"mcp",
		"gc",
		"inspect",
		"migrate"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outfile dist/index.js --target bun --format esm"
	},
	"dependencies": {
		"@stateful-mcp/core": "workspace:^"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^20",
		"typescript": "^5"
	}
}
