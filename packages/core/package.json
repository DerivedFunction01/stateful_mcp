{
	"name": "@stateful-mcp/core",
	"version": "0.1.2",
	"description": "Stateful framework core (transport and LLM-agnostic)",
	"keywords": [
		"stateful",
		"middleware",
		"filter",
		"version-control",
		"vcs",
		"object",
		"event",
		"form",
		"dictionary",
		"dag"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"test": "bun test.ts",
		"build": "bun build ./src/index.ts --outfile dist/index.js --target bun --format esm && tsc --emitDeclarationOnly --declaration --outDir dist"
	},
	"dependencies": {
		"@duckdb/node-api": "^1.5.4-r.1",
		"@sqlite.org/sqlite-wasm": "latest",
		"ajv": "^8.20.0",
		"pg": "^8.22.0",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"typescript": "^5"
	},
	"optionalDependencies": {
		"duckdb": "^1.4.4"
	}
}
