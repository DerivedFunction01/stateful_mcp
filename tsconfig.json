{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Path aliases — usable in external adapters without relative paths
    "baseUrl": ".",
    "paths": {
      "@stateful-mcp/loader":    ["src/config/loader.ts"],
      "@stateful-mcp/types":     ["src/config/types.ts"],
      "@stateful-mcp/errors":    ["src/errors/types.ts"],
      "@stateful-mcp/*":         ["src/*"]
    }
  }
}

